#!/usr/bin/env python3
# =====================================================================================
#  R3 — STATISTICAL VALIDATION (same exhaustive ELU-family protocol)
#  Compares DOMCS-EEG vs published baselines using per-seed B2T EER, re-evaluated under
#  the SAME exhaustive all-impostor scorer as R1/R2 (no protocol mixing).
#    * DOMCS vs DANN (Ganin et al., JMLR 2016): 5 seeds each -> PAIRED t-test (+Wilcoxon).
#    * DOMCS vs CNN+ArcFace: only 1 baseline seed -> ONE-SAMPLE t-test (declared).
#  Reports t, df, p (one/two-tailed), Cohen's d, and bootstrap 95% CI.
#  Self-verifies: DOMCS per-seed EERs must match R1 (2.256/2.210/2.259/2.558/2.717).
# =====================================================================================
import os, json, numpy as np, torch, torch.nn as nn, torch.nn.functional as F
from sklearn.cluster import KMeans
from sklearn.metrics import roc_curve, roc_auc_score
from scipy import stats

ROOT   = "/home/nvidia/24PHD1237/FRESH_EXP_20260528_DOMCS_EEG"
DOMCS  = ROOT+"/08_ablation_ELU_FINAL/E1/seed_{}/model_best.pt"          # 5 seeds
DANN   = "/home/nvidia/24PHD1237/DANN_PHYSIONET_RESULTS/seed_{}/model_best.pt"  # 5 seeds
CNN    = ROOT+"/12_baseline_adversarial_v2/cnn_arcface_rest_only_best.pt"       # 1 seed
DATA   = os.environ.get("DATA", "/home/nvidia/24PHD1237/EEGMMIDB/EEGMMIDB_win2s_step1s_fs128.npz")
OUTDIR = ROOT+"/R3_stats"; os.makedirs(OUTDIR, exist_ok=True)
DEV    = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
K, SEEDS = 3, [1,2,3,4,5]
R1_DOMCS = [2.256,2.210,2.259,2.558,2.717]   # R1 reference for self-check

# ---- architectures ----
class CB(nn.Module):
    def __init__(s,ic,oc,k,p=None):
        super().__init__(); p=k//2 if p is None else p
        s.net=nn.Sequential(nn.Conv1d(ic,oc,k,padding=p,bias=False),nn.BatchNorm1d(oc),nn.ELU(inplace=True))
    def forward(s,x): return s.net(x)
# DOMCS worker (E1): enc.0..3 + id_fc/id_n (+ state branch ignored at inference)
class DOMCS_E1(nn.Module):
    def __init__(s):
        super().__init__(); s.enc=nn.Sequential(CB(64,64,7),CB(64,128,5),CB(128,256,3),nn.AdaptiveAvgPool1d(1))
        s.id_fc=nn.Linear(256,128,bias=False); s.id_n=nn.LayerNorm(128)
        s.st_fc=nn.Linear(256,128,bias=False); s.st_n=nn.LayerNorm(128)
    def forward(s,x):
        f=s.enc(x).squeeze(-1); return F.normalize(s.id_n(s.id_fc(f)),dim=-1)
# DANN (Ganin et al., JMLR 2016) — VERIFIED from checkpoint keys: encoder.{0,1,2}.net.{0,1}
# (Sequential of ConvBlocks) + id_head=Sequential(Linear(256,128,bias=F), LayerNorm). The
# domain_head (GRL state classifier, ...->Linear(128,2)) and arc_w are dropped at inference.
class DANNNet(nn.Module):
    def __init__(s):
        super().__init__()
        s.encoder=nn.Sequential(CB(64,64,7),CB(64,128,5),CB(128,256,3),nn.AdaptiveAvgPool1d(1))
        s.id_head=nn.Sequential(nn.Linear(256,128,bias=False),nn.LayerNorm(128))
    def forward(s,x): return F.normalize(s.id_head(s.encoder(x).squeeze(-1)),dim=-1)
class CNNArcFace(nn.Module):                    # flat baseline (conv1/2/3+fc+norm)
    def __init__(s):
        super().__init__(); s.conv1=CB(64,64,7,3); s.conv2=CB(64,128,5,2); s.conv3=CB(128,256,3,1)
        s.pool=nn.AdaptiveAvgPool1d(1); s.fc=nn.Linear(256,128,bias=False); s.norm=nn.LayerNorm(128)
    def forward(s,x):
        f=s.pool(s.conv3(s.conv2(s.conv1(x)))).squeeze(-1); return F.normalize(s.norm(s.fc(f)),dim=1)

def _state(ck): return ck.get("model_state",ck.get("model_state_dict",ck.get("state_dict",ck)))
def load(kind,path):
    ck=torch.load(path,map_location=DEV,weights_only=False)
    if kind=="domcs":
        m=DOMCS_E1(); assert ck.get("activation")=="ELU"; m.load_state_dict(_state(ck),strict=True)
    else:
        m=DANNNet() if kind=="dann" else CNNArcFace()
        res=m.load_state_dict(_state(ck),strict=False)
        assert not res.missing_keys, f"{kind} missing keys: {res.missing_keys[:6]}"
    return m.eval().to(DEV)

# ---- data + exhaustive EER ----
d=np.load(DATA,allow_pickle=True); X=d["X"].astype(np.float32); y=d["y"].astype(np.int64)
sess=np.array([int(str(s).lstrip("Rr")) for s in d["session"]]); rest=np.isin(sess,[1,2]); task=~rest
SUBJ=sorted(np.unique(y)); s2i={s:i for i,s in enumerate(SUBJ)}; NS=len(SUBJ)
@torch.no_grad()
def emb(m,Xn,bs=4096):
    o=[]
    for i in range(0,len(Xn),bs): o.append(m(torch.from_numpy(Xn[i:i+bs]).to(DEV)).cpu().numpy())
    return np.concatenate(o)
def exh_eer(m):
    zr=emb(m,X[rest]); yr=y[rest]; G=np.zeros((NS,K,128),np.float32)
    for s in SUBJ:
        c=KMeans(K,n_init=10,random_state=0).fit(zr[yr==s]).cluster_centers_
        G[s2i[s]]=c/(np.linalg.norm(c,axis=1,keepdims=True)+1e-12)
    zt=emb(m,X[task]); Gt=torch.tensor(G.reshape(NS*K,128),device=DEV); P=torch.tensor(zt,device=DEV)
    gen=[]; imp=[]
    with torch.no_grad():
        for i in range(0,len(P),8192):
            S=(P[i:i+8192]@Gt.T).view(-1,NS,K).max(2).values.cpu().numpy()
            yb=y[task][i:i+8192]; r=np.arange(len(yb)); gi=np.array([s2i[s] for s in yb])
            gen.append(S[r,gi]); M=S.copy(); M[r,gi]=np.nan; imp.append(M[~np.isnan(M)])
    gen=np.concatenate(gen); imp=np.concatenate(imp)
    sc=np.r_[gen,imp].astype(np.float64); lb=np.r_[np.ones_like(gen),np.zeros_like(imp)]
    fpr,tpr,_=roc_curve(lb,sc); fnr=1-tpr; i=np.nanargmin(np.abs(fnr-fpr))
    return (fpr[i]+fnr[i])/2*100

# ---- per-seed EER (exhaustive) ----
print("Re-evaluating per-seed EER under exhaustive scorer ...")
dm=[exh_eer(load("domcs",DOMCS.format(s))) for s in SEEDS]; print("  DOMCS:",[f"{x:.3f}" for x in dm])
dn=[exh_eer(load("dann", DANN.format(s)))  for s in SEEDS]; print("  DANN :",[f"{x:.3f}" for x in dn])
cn=exh_eer(load("cnn",CNN));                                 print(f"  CNN+ArcFace (1 seed): {cn:.3f}")
dm=np.array(dm); dn=np.array(dn)

# self-check vs R1
assert np.allclose(dm,R1_DOMCS,atol=0.05), f"DOMCS EERs drifted from R1: {dm} vs {R1_DOMCS}"
print("  self-check: DOMCS per-seed matches R1 (within 0.05pp) OK")

def cohen_paired(a,b): dif=b-a; return dif.mean()/dif.std(ddof=1)
def boot_ci(a,n=10000):
    bs=[np.mean(np.random.choice(a,len(a),replace=True)) for _ in range(n)]; return np.percentile(bs,[2.5,97.5])

res={"domcs_eers":dm.tolist(),"dann_eers":dn.tolist(),"cnn_eer":cn}
# DOMCS vs DANN — paired
t,p2=stats.ttest_rel(dm,dn); w,wp=stats.wilcoxon(dm,dn); dco=cohen_paired(dm,dn)
res["DOMCS_vs_DANN"]=dict(domcs=f"{dm.mean():.3f}+/-{dm.std(ddof=1):.3f}",dann=f"{dn.mean():.3f}+/-{dn.std(ddof=1):.3f}",
    delta_pp=float(dn.mean()-dm.mean()),t=float(t),df=len(dm)-1,p_two=float(p2),p_one=float(p2/2),
    cohen_d=float(dco),wilcoxon_p=float(wp))
# DOMCS vs CNN+ArcFace — DESCRIPTIVE ONLY (single baseline seed; no formal significance
# claim because n=1 has no variance. CNN+ArcFace's formal comparison lives in R2 security).
res["DOMCS_vs_CNNArcFace"]=dict(role="DESCRIPTIVE ONLY (1 seed) — formal comparison is in R2 security, NOT here",
    domcs=f"{dm.mean():.3f}+/-{dm.std(ddof=1):.3f}",cnn=float(cn),delta_pp=float(cn-dm.mean()))
res["DOMCS_bootstrap95CI"]=boot_ci(dm).tolist()

json.dump(res,open(OUTDIR+"/R3_stats_results.json","w"),indent=2)
print("\n======== RESULTS ========")
R=res["DOMCS_vs_DANN"]; print(f"DOMCS {R['domcs']}% vs DANN {R['dann']}%  Delta={R['delta_pp']:.3f}pp")
print(f"  PAIRED t({R['df']})={R['t']:.3f}  p_two={R['p_two']:.4f}  p_one={R['p_one']:.4f}  d={R['cohen_d']:.2f}  Wilcoxon p={R['wilcoxon_p']:.4f}")
C=res["DOMCS_vs_CNNArcFace"]; print(f"DOMCS {C['domcs']}% vs CNN+ArcFace {C['cnn']:.3f}% (1 seed)  Delta={C['delta_pp']:.3f}pp  [DESCRIPTIVE ONLY]")
print(f"DOMCS bootstrap 95% CI: [{res['DOMCS_bootstrap95CI'][0]:.3f}, {res['DOMCS_bootstrap95CI'][1]:.3f}]")
star=lambda p:'***' if p<0.001 else '**' if p<0.01 else '*' if p<0.05 else 'ns'
print(f"\nTABLE VII footnote (FORMAL significance = DANN only): DOMCS-EEG {dm.mean():.2f}+/-{dm.std(ddof=1):.2f}% vs "
      f"DANN {dn.mean():.2f}+/-{dn.std(ddof=1):.2f}% (Delta={R['delta_pp']:.2f}pp, paired t({R['df']})={R['t']:.2f}, "
      f"p={R['p_one']:.3f}{star(R['p_one'])}, Wilcoxon p={R['wilcoxon_p']:.3f}, Cohen d={R['cohen_d']:.2f}, "
      f"DOMCS 95% CI [{res['DOMCS_bootstrap95CI'][0]:.2f},{res['DOMCS_bootstrap95CI'][1]:.2f}]). "
      f"CNN+ArcFace ({cn:.2f}%, single seed) reported descriptively; its formal comparison is the R2 security battery.")
print("\nDONE. All under exhaustive ELU-family scorer. DANN cite: Ganin et al., JMLR 2016.")
