import os, json, numpy as np, torch, torch.nn as nn, torch.nn.functional as F

# ----------------------------- CONFIG --------------------------------
ABLATION_ROOT = "/home/nvidia/24PHD1237/FRESH_EXP_20260528_DOMCS_EEG/08_ablation_ELU_FINAL"
DATA_NPZ      = os.environ.get("DATA", "/home/nvidia/24PHD1237/EEGMMIDB/EEGMMIDB_win2s_step1s_fs128.npz")
DEVICE        = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
VARIANTS, SEEDS = ["E1","E2","E3","E4","E5"], [1,2,3,4,5]
REST_RUNS     = {1, 2}          # R01,R02 -> gallery   (state==0)
GALLERY_K     = 3
RUN_EER       = True            # False -> |cos| table only

# ===== Architecture: VERBATIM from ablation_worker_elu.py (ELU) ======
class ConvBlock(nn.Module):
    def __init__(self, ic, oc, k):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv1d(ic, oc, kernel_size=k, padding=k//2, bias=False),
            nn.BatchNorm1d(oc), nn.ELU(inplace=True))
    def forward(self, x): return self.net(x)

def _encoder():
    return nn.Sequential(ConvBlock(64,64,7), ConvBlock(64,128,5),
                         ConvBlock(128,256,3), nn.AdaptiveAvgPool1d(1))

class DOMCSStandard(nn.Module):                 # E1/E2/E4/E5 (f.detach in state branch)
    def __init__(self):
        super().__init__()
        self.enc=_encoder()
        self.id_fc=nn.Linear(256,128,bias=False); self.id_n=nn.LayerNorm(128)
        self.st_fc=nn.Linear(256,128,bias=False); self.st_n=nn.LayerNorm(128)
    def forward(self, x):
        f=self.enc(x).squeeze(-1)
        return (F.normalize(self.id_n(self.id_fc(f)),          dim=-1),
                F.normalize(self.st_n(self.st_fc(f.detach())), dim=-1))

class DOMCSNoDetach(nn.Module):                 # E3 (no detach)
    def __init__(self):
        super().__init__()
        self.enc=_encoder()
        self.id_fc=nn.Linear(256,128,bias=False); self.id_n=nn.LayerNorm(128)
        self.st_fc=nn.Linear(256,128,bias=False); self.st_n=nn.LayerNorm(128)
    def forward(self, x):
        f=self.enc(x).squeeze(-1)
        return (F.normalize(self.id_n(self.id_fc(f)), dim=-1),
                F.normalize(self.st_n(self.st_fc(f)), dim=-1))

def load_ablation_model(variant, seed):
    path = os.path.join(ABLATION_ROOT, variant, f"seed_{seed}", "model_best.pt")
    ck = torch.load(path, map_location=DEVICE)
    assert ck.get("activation") == "ELU", f"{path}: activation={ck.get('activation')}"
    m = (DOMCSNoDetach() if variant == "E3" else DOMCSStandard()).to(DEVICE)
    m.load_state_dict(ck["model_state"], strict=True)
    m.eval()
    return m, ck

# ===== Data + B2T masks (same fields the worker used) ================
_d    = np.load(DATA_NPZ, allow_pickle=True)
_X    = _d["X"].astype(np.float32)
_y    = _d["y"].astype(np.int64)
_sess = np.array([int(str(s).lstrip("Rr")) for s in _d["session"]], dtype=np.int64)
_rest = np.isin(_sess, list(REST_RUNS))         # gallery windows
_task = ~_rest                                  # probe windows
_subj2idx = {s: i for i, s in enumerate(sorted(np.unique(_y)))}
print(f"data: {len(_X)} windows | gallery(REST)={_rest.sum()} | probe(TASK)={_task.sum()} "
      f"| subjects={len(_subj2idx)}")

def val_split(seed):                            # worker's per-seed 10% val (for |cos|)
    rng = np.random.default_rng(seed)
    idx = rng.permutation(len(_X))
    return idx[:int(0.10*len(idx))]

@torch.no_grad()
def mean_abs_cos(model, Xnp, bs=1024):
    tot, n = 0.0, 0
    for i in range(0, len(Xnp), bs):
        zi, zs = model(torch.from_numpy(Xnp[i:i+bs]).to(DEVICE))
        c = torch.abs(F.cosine_similarity(zi, zs, dim=-1))
        tot += c.sum().item(); n += c.numel()
    return tot / max(n, 1)

# ----- EER: reuse kernel build_gallery + compute_clean_eer -----------
_have_eer = all(f in globals() for f in ("build_gallery", "compute_clean_eer"))
if RUN_EER and not _have_eer:
    print("[warn] build_gallery/compute_clean_eer not in kernel -> EER skipped. "
          "Run Cell 4 first, or set RUN_EER=False.")
    RUN_EER = False

@torch.no_grad()
def b2t_eer(model):
    gallery = build_gallery(model, _X[_rest], _y[_rest], K=GALLERY_K)
    return float(compute_clean_eer(model, _X[_task], _y[_task], gallery, _subj2idx))

# ============================ run ====================================
results = {v: {"eer": [], "cos": []} for v in VARIANTS}
for v in VARIANTS:
    for s in SEEDS:
        model, ck = load_ablation_model(v, s)
        cos = mean_abs_cos(model, _X[val_split(s)])
        eer = (b2t_eer(model) if RUN_EER else float("nan"))
        results[v]["cos"].append(cos); results[v]["eer"].append(eer)
        print(f"  {v}/seed_{s}: |cos|={cos:.4f}  EER={eer:.3f}%  "
              f"(ep{ck['best_epoch']}, orth={ck['use_orth']}, arc={ck['use_arcface']}, sup={ck['lam_sup']})")

# ----------------------------- aggregate -----------------------------
summary = {}
for v in VARIANTS:
    cos = np.array(results[v]["cos"]); eer = np.array(results[v]["eer"])
    summary[v] = {"cos_mean": float(cos.mean()), "cos_std": float(cos.std(ddof=1)),
                  "eer_mean": float(np.nanmean(eer)), "eer_std": float(np.nanstd(eer, ddof=1)),
                  "cos_raw": cos.tolist(), "eer_raw": eer.tolist(), "n_seeds": len(cos)}
e1 = summary["E1"]["cos_mean"]
for v in VARIANTS:
    summary[v]["cos_ratio_vs_E1"] = float(summary[v]["cos_mean"]/e1) if e1 else None

out = os.path.join(ABLATION_ROOT, "all_results_final.json")
json.dump({"per_seed": results, "summary": summary}, open(out, "w"), indent=2)
print(f"\nSaved -> {out}")

