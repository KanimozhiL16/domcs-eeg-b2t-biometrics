#  FINAL SAME-FAMILY METRICS — 08_ablation_ELU_FINAL ONLY (ELU)
#  Self-contained (NO kernel functions) → avoids the (z_id,z_state)
#  tuple bug in kernel embed()/build_gallery().
#
#  Computes, all from ONE checkpoint family:
#    Per variant E1-E5 (5 seeds): B2T EER, AUC, M5 |cos(z_id,z_state)|
#    For E1 (main model, 5 seeds): M1 balanced state-probe on z_id,
#                                  M2 cross-state genuine cosine,
#                                  M3 MMD(z_id REST, z_id TASK)
#  Metric definitions are documented inline so the paper can state them.
#  Writes final_metrics_ELU.json + prints paper tables.
# =====================================================================
import os, json, numpy as np, torch, torch.nn as nn, torch.nn.functional as F
from sklearn.cluster import KMeans
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import roc_curve, roc_auc_score

ABLATION_ROOT = "/home/nvidia/24PHD1237/FRESH_EXP_20260528_DOMCS_EEG/08_ablation_ELU_FINAL"
DATA_NPZ      = os.environ.get("DATA", "/home/nvidia/24PHD1237/EEGMMIDB/EEGMMIDB_win2s_step1s_fs128.npz")
DEVICE        = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
VARIANTS, SEEDS = ["E1","E2","E3","E4","E5"], [1,2,3,4,5]
REST_RUNS, K  = {1,2}, 3
# Scoring declarations (state these in the paper):
#   EER/AUC = EXHAUSTIVE all-impostor B2T: gallery=REST KMeans K=3/subject,
#             probe=TASK, score=max cosine to a subject's K prototypes;
#             each probe scored vs its own subject (genuine) and ALL 108
#             other subjects (impostor). Deterministic — no impostor sampling.
#   M5 |cos(z_id,z_state)| measured on TASK verification windows.

# ===== Architecture VERBATIM from ablation_worker_elu.py (ELU) =======
class ConvBlock(nn.Module):
    def __init__(s,ic,oc,k):
        super().__init__()
        s.net=nn.Sequential(nn.Conv1d(ic,oc,k,padding=k//2,bias=False),
                            nn.BatchNorm1d(oc),nn.ELU(inplace=True))
    def forward(s,x): return s.net(x)
def _enc(): return nn.Sequential(ConvBlock(64,64,7),ConvBlock(64,128,5),
                                 ConvBlock(128,256,3),nn.AdaptiveAvgPool1d(1))
class DOMCSStandard(nn.Module):
    def __init__(s):
        super().__init__(); s.enc=_enc()
        s.id_fc=nn.Linear(256,128,bias=False); s.id_n=nn.LayerNorm(128)
        s.st_fc=nn.Linear(256,128,bias=False); s.st_n=nn.LayerNorm(128)
    def forward(s,x):
        f=s.enc(x).squeeze(-1)
        return (F.normalize(s.id_n(s.id_fc(f)),dim=-1),
                F.normalize(s.st_n(s.st_fc(f.detach())),dim=-1))
class DOMCSNoDetach(DOMCSStandard):
    def forward(s,x):
        f=s.enc(x).squeeze(-1)
        return (F.normalize(s.id_n(s.id_fc(f)),dim=-1),
                F.normalize(s.st_n(s.st_fc(f)),dim=-1))

def load_model(variant,seed):
    p=os.path.join(ABLATION_ROOT,variant,f"seed_{seed}","model_best.pt")
    ck=torch.load(p,map_location=DEVICE)
    assert ck.get("activation")=="ELU", f"{p}: activation={ck.get('activation')}"
    m=(DOMCSNoDetach() if variant=="E3" else DOMCSStandard()).to(DEVICE)
    m.load_state_dict(ck["model_state"],strict=True); m.eval()
    return m,ck

# ===== Data =========================================================
d   = np.load(DATA_NPZ,allow_pickle=True)
X   = d["X"].astype(np.float32); y = d["y"].astype(np.int64)
sess= np.array([int(str(s).lstrip("Rr")) for s in d["session"]],dtype=np.int64)
rest= np.isin(sess,list(REST_RUNS)); task=~rest
subj2idx={s:i for i,s in enumerate(sorted(np.unique(y)))}
print(f"data: {len(X)} windows | REST={rest.sum()} TASK={task.sum()} | subj={len(subj2idx)}")

@torch.no_grad()
def embed_id(model,Xnp,bs=2048):           # returns z_id (N,128) normalized
    out=[]
    for i in range(0,len(Xnp),bs):
        zi,_=model(torch.from_numpy(Xnp[i:i+bs]).to(DEVICE))
        out.append(zi.cpu().numpy())
    return np.concatenate(out)

@torch.no_grad()
def mean_abs_cos(model,Xnp,bs=2048):       # M5: mean_i |cos(z_id_i, z_state_i)|
    tot=n=0
    for i in range(0,len(Xnp),bs):
        zi,zs=model(torch.from_numpy(Xnp[i:i+bs]).to(DEVICE))
        c=torch.abs(F.cosine_similarity(zi,zs,dim=-1)); tot+=c.sum().item(); n+=c.numel()
    return tot/max(n,1)

# ----- B2T EER (self-contained, EXHAUSTIVE all-impostor) --------------
def b2t_eer_auc(model):
    zr=embed_id(model,X[rest]); yr=y[rest]
    zt=embed_id(model,X[task]); yt=y[task]
    cents=[]
    for s in sorted(np.unique(yr)):
        c=KMeans(n_clusters=K,n_init=10,random_state=0).fit(zr[yr==s]).cluster_centers_
        cents.append(c/(np.linalg.norm(c,axis=1,keepdims=True)+1e-12))
    C=torch.tensor(np.concatenate(cents),dtype=torch.float32,device=DEVICE)   # (nsub*K,128)
    nsub=len(np.unique(yr))
    Pt=torch.tensor(zt,dtype=torch.float32,device=DEVICE)
    gen=[]; imp=[]
    with torch.no_grad():
        for i in range(0,len(Pt),8192):
            S=(Pt[i:i+8192]@C.T).view(-1,nsub,K).max(dim=2).values.cpu().numpy()  # (b,nsub)
            yb=yt[i:i+8192]; rows=np.arange(len(yb))
            gi=np.array([subj2idx[s] for s in yb])
            gen.append(S[rows,gi])
            M=S.copy(); M[rows,gi]=np.nan          # remove genuine column
            imp.append(M[~np.isnan(M)])            # ALL other subjects = exhaustive impostors
    gen=np.concatenate(gen); imp=np.concatenate(imp)
    sc=np.r_[gen,imp].astype(np.float64); lb=np.r_[np.ones_like(gen),np.zeros_like(imp)]
    fpr,tpr,_=roc_curve(lb,sc); fnr=1-tpr
    eer=fpr[np.nanargmin(np.abs(fnr-fpr))]*100
    return eer, roc_auc_score(lb,sc)

# ----- M1/M2/M3 (E1 main model). DEFINITIONS (state these in paper):
#  M1 = test accuracy of a balanced logistic probe z_id -> state(REST/TASK),
#       equal REST/TASK samples, 70/30 split. Chance = 50%.
#  M2 = mean over subjects of cos( mean z_id over that subject's REST ,
#       mean z_id over that subject's TASK ). "cross-state genuine cosine."
#  M3 = RBF-MMD^2 between z_id(REST) and z_id(TASK), sigma=median heuristic,
#       2000 samples each. 0 = identical distributions.
def m1_balanced_probe(zid,rng):
    ir=np.where(rest)[0]; it=np.where(task)[0]
    n=min(len(ir),len(it)); it=rng.choice(it,n,replace=False)
    Xp=np.r_[zid[ir],zid[it]]; yp=np.r_[np.zeros(len(ir)),np.ones(n)]
    p=rng.permutation(len(Xp)); Xp,yp=Xp[p],yp[p]; cut=int(0.7*len(Xp))
    clf=LogisticRegression(max_iter=1000).fit(Xp[:cut],yp[:cut])
    return clf.score(Xp[cut:],yp[cut:])*100
def m2_cross_state_cos(zid):
    vals=[]
    for s in np.unique(y):
        r=zid[(y==s)&rest].mean(0); t=zid[(y==s)&task].mean(0)
        vals.append(np.dot(r,t)/((np.linalg.norm(r)*np.linalg.norm(t))+1e-12))
    return float(np.mean(vals))
def m3_mmd(zid,rng,n=2000):
    a=zid[rest][rng.choice(rest.sum(),min(n,rest.sum()),replace=False)]
    b=zid[task][rng.choice(task.sum(),min(n,task.sum()),replace=False)]
    Z=np.r_[a,b]; d2=np.sum((Z[:,None]-Z[None])**2,-1); sig=np.median(d2[d2>0])
    k=lambda U,V: np.exp(-np.sum((U[:,None]-V[None])**2,-1)/(sig+1e-12))
    return float(k(a,a).mean()+k(b,b).mean()-2*k(a,b).mean())

# ============================ run ===================================
res={v:{"eer":[],"auc":[],"cos":[]} for v in VARIANTS}
m1=m2=m3=None; M1,M2,M3=[],[],[]
for v in VARIANTS:
    for s in SEEDS:
        rng=np.random.default_rng(s)        # local, per-seed → order-independent
        model,ck=load_model(v,s)
        eer,auc=b2t_eer_auc(model); cos=mean_abs_cos(model,X[task])
        res[v]["eer"].append(eer); res[v]["auc"].append(auc); res[v]["cos"].append(cos)
        line=f"  {v}/s{s}: EER={eer:.3f}% AUC={auc:.4f} |cos|={cos:.4f}"
        if v=="E1":
            zid=embed_id(model,X)
            a,b,c=m1_balanced_probe(zid,rng),m2_cross_state_cos(zid),m3_mmd(zid,rng)
            M1.append(a); M2.append(b); M3.append(c)
            line+=f" | M1={a:.1f}% M2={b:.3f} M3={c:.4f}"
        print(line)

def ms(x): x=np.array(x); return float(x.mean()),float(x.std(ddof=1))
