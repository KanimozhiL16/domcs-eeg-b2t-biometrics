*.npz
*.npy
*.mat
*.h5
*.hdf5
*.edf
data/*.npz
data/*.mat

# --- BED is license-restricted: never commit any BED data array ---
*BED*win*.npz
*bed*win*.npz
BED_DATASET/

# --- Python / OS junk ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
*.tmp
_mvtest_*

